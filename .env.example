ENV=development
LOG_LEVEL=INFO

BOT_TOKEN=123456:ABCDEF_example_token
DATABASE_URL=sqlite+aiosqlite:///./data/dev.sqlite3
# DATABASE_URL=postgresql+asyncpg://networking_bot:networking_bot@localhost:5432/networking_bot

ADMIN_TELEGRAM_IDS=[123456789,987654321]

DEFAULT_LANGUAGE=uz
DEFAULT_TIMEZONE=Asia/Tashkent

USE_WEBHOOK=false
WEBHOOK_URL=
WEBHOOK_SECRET=

HOST=0.0.0.0
PORT=8080

DB_ECHO=false

ENABLE_SCHEDULER=false
REMINDER_CHECK_INTERVAL_MINUTES=5
REMINDER_SCHEDULER_LOOKBACK_MINUTES=10
REMINDER_SCRIPT_LOOKBACK_MINUTES=1440

EXCEL_MAX_FILE_SIZE_MB=5
BACKUP_MAX_FILE_SIZE_MB=10

